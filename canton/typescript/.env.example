# M1 Global API access
M1_API_BASE_URL=https://api.m1global.xyz/api/1.0
M1_API_JWT=

# Canton participant base URL (e.g. https://participant.canton.example.com)
CANTON_BASE_URL=

# Keycloak base URL for the Canton deployment
# (e.g. https://auth.canton.example.com/realms/canton)
CANTON_KEYCLOAK_URL=
CANTON_KEYCLOAK_CLIENT_ID=
CANTON_KEYCLOAK_CLIENT_SECRET=

# Customer Canton identity
CANTON_PARTY_ID=
CANTON_USER_ID=
CANTON_USERNAME=
CANTON_PASSWORD=
# Password is passed as a CLI argument (-p / --password) rather than stored here.

# Collateral selection from the broker bundle
CANTON_COLLATERAL_ID=MOCK

# Deposit amount in collateral units (defaults to 100 if unset)
CANTON_DEPOSIT_AMOUNT=100

# Standing RecipientMintAuth limit used during deposit onboarding.
# Must be positive. Defaults to 1000000000 if unset.
CANTON_RECIPIENT_MINT_AUTH_MAX_MINT_AMOUNT=1000000000
